{
  "format_version": "1.10.0",
  "animations": {
    "animation.wildfire.idle": {
      "loop": true,
      "bones": {
        "root": {
          "position": [
            0,
            "math.sin(query.life_time * 115) * 0.25",
            0
          ]
        },
        "body": {
          "rotation": [
            0,
            "query.life_time * -55",
            0
          ]
        },
        "head": {
          "position": [
            0,
            "math.sin(query.life_time * 150) * 0.16",
            0
          ],
          "rotation": [
            "query.target_x_rotation * 0.3",
            "query.target_y_rotation * 0.3",
            0
          ]
        },
        "shields_root": {
          "rotation": [
            0,
            "query.life_time * 105",
            0
          ],
          "position": [
            0,
            "math.sin(query.life_time * 140) * 0.22",
            0
          ]
        },
        "shield_front": {
          "scale": [
            "query.mark_variant >= 1 ? 1 : 0",
            "query.mark_variant >= 1 ? 1 : 0",
            "query.mark_variant >= 1 ? 1 : 0"
          ]
        },
        "shield_right": {
          "scale": [
            "query.mark_variant >= 4 ? 1 : 0",
            "query.mark_variant >= 4 ? 1 : 0",
            "query.mark_variant >= 4 ? 1 : 0"
          ]
        },
        "shield_back": {
          "scale": [
            "query.mark_variant >= 7 ? 1 : 0",
            "query.mark_variant >= 7 ? 1 : 0",
            "query.mark_variant >= 7 ? 1 : 0"
          ]
        },
        "shield_left": {
          "scale": [
            "query.mark_variant >= 10 ? 1 : 0",
            "query.mark_variant >= 10 ? 1 : 0",
            "query.mark_variant >= 10 ? 1 : 0"
          ]
        }
      }
    },
    "animation.wildfire.attack": {
      "loop": true,
      "bones": {
        "shields_root": {
          "rotation": [
            0,
            "query.life_time * 430",
            0
          ]
        },
        "root": {
          "position": [
            0,
            "math.sin(query.life_time * 260) * 0.55",
            0
          ]
        }
      }
    },
    "animation.wildfire.hurt": {
      "loop": false,
      "animation_length": 0.25,
      "bones": {
        "root": {
          "rotation": [
            0,
            0,
            "math.sin(query.life_time * 900) * 5"
          ]
        }
      }
    }
  }
}